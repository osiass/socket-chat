@page "/"
@using ChatApp.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="card p-4 shadow border-0 w-100">
            <h2 class="text-center mb-4 fw-bold text-primary">SocialApp</h2>

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">KULLANICI ADI</label>
                <input class="form-control bg-light border-0" @bind="username" placeholder="Kullanıcı adınız" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">ŞİFRE</label>
                <input type="password" class="form-control bg-light border-0" @bind="password" placeholder="Şifreniz" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger p-2 small text-center">@errorMessage</div>
            }

            <button class="btn btn-primary w-100 fw-bold py-2 mt-2" @onclick="HandleLogin">
                Giriş Yap
            </button>

            <hr class="text-muted mt-4" />
            <p class="text-center small">
                Hesabın yok mu? <a href="/register" class="text-primary text-decoration-none fw-bold">Kayıt Ol</a>
            </p>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        // AuthService içindeki metod kontrol yapıyor
        // başarılıysa UserSessionı dolduruyor.
        bool result = await AuthService.LoginUserAsync(username, password);

        if (result)
        {
            Navigation.NavigateTo("/feed");
        }
        else
        {
            errorMessage = "Kullanıcı adı veya şifre hatalı!";
        }
    }
}