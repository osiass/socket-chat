@page "/"
@using ChatApp.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject UserSession UserSession
<PageTitle>Giriş Yap</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card p-4 shadow">
            <h3 class="text-center">Giriş Yap</h3>

            <div class="mb-3">
                <label>Kullanıcı Adı</label>
                <input class="form-control" @bind="username" />
            </div>

            <div class="mb-3">
                <label>Şifre</label>
                <input type="password" class="form-control" @bind="password" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <button class="btn btn-success w-100" @onclick="HandleLogin">Giriş Yap</button>

            <hr />
            <p class="text-center">Hesabın yok mu? <a href="/register">Kayıt Ol</a></p>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        bool result = await AuthService.LoginUserAsync(username, password);

        if (result)
        {
            // Kullanıcı adını seansa kaydet
            UserSession.Username = username;

            Navigation.NavigateTo("/chat");
        }
        else
        {
            errorMessage = "Kullanıcı adı veya şifre hatalı!";
        }
    }
}