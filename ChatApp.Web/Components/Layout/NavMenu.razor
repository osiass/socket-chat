@using ChatApp.Web.Services
@inject UserSession UserSession

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SocialApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />
@*nav link ile <a> etiketinden kurtuluyoruz, eğer bulunulan sayfa ile href adresi eşleşiyorsa otomatik active sınıfını ekler *@
<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="feed">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Akış
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="chat">
                <span class="bi bi-chat-dots-fill" aria-hidden="true"></span> Sohbet
            </NavLink>
        </div>

        @if (UserSession.IsLoggedIn)
        {
            <div class="nav-item px-3">
                @* Giriş yapan kullanıcının ID ile profile gitme *@
                <NavLink class="nav-link" href="@($"/profile/{UserSession.UserId}")">
                    <span class="bi bi-person-fill" aria-hidden="true"></span> Profilim
                </NavLink>
            </div>
        }
    </nav>
</div>